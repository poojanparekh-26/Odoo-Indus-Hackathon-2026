{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "paths": { "@/*": ["./*"] }
  },
  "include": ["server.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
